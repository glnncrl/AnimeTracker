@{
    ViewData["Title"] = "Privacy";
}

<div class="container mt-4 mb-5" style="max-width:720px;">

    <div class="text-center mb-5">
        <h2 style="font-family:'Cinzel',serif; color:#e9d5ff; letter-spacing:3px;">🔒 Privacy Policy</h2>
        <p style="color:#a78bfa; letter-spacing:1px; font-size:0.9rem;">Last updated: May 2026</p>
    </div>

    <div class="anime-card mb-4">
        <h5 style="font-family:'Cinzel',serif; color:#c084fc; margin-bottom:1rem;">📦 Your Data Stays With You</h5>
        <p style="color:#d8b4fe; line-height:1.8;">
            AnimeTracker stores all your data locally on your own SQL Server database.
            Nothing you enter — your anime titles, ratings, or notes — is ever sent to any
            external server or third party. Your collection is entirely yours.
        </p>
    </div>

    <div class="anime-card mb-4">
        <h5 style="font-family:'Cinzel',serif; color:#c084fc; margin-bottom:1rem;">🌐 No Tracking, No Ads</h5>
        <p style="color:#d8b4fe; line-height:1.8;">
            This application does not use cookies for tracking, does not display advertisements,
            and does not collect any personal information. There are no analytics tools or
            third-party scripts monitoring your activity.
        </p>
    </div>

    <div class="anime-card mb-4">
        <h5 style="font-family:'Cinzel',serif; color:#c084fc; margin-bottom:1rem;">🗄️ Database Storage</h5>
        <p style="color:#d8b4fe; line-height:1.8;">
            Your anime collection data is stored in a local SQL Server database
            (AnimeTrackerDB) running on your own machine. Only you have access to this data.
            Uninstalling the application or dropping the database permanently removes all stored data.
        </p>
    </div>

    <div class="anime-card mb-4">
        <h5 style="font-family:'Cinzel',serif; color:#c084fc; margin-bottom:1rem;">✉️ Contact</h5>
        <p style="color:#d8b4fe; line-height:1.8;">
            This is a personal project built with ASP.NET Core MVC and SQL Server.
            If you have any questions or concerns about how this application works,
            feel free to review the source code or reach out to the developer directly.
        </p>
    </div>

    <div class="text-center mt-4 mb-4">
        <a asp-controller="Anime" asp-action="Index" class="btn btn-primary">🎌 Back to My Collection</a>
    </div>

