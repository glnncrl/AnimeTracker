@model AnimeTracker.Models.Anime

@{
    ViewData["Title"] = "Anime Details";
}

<div class="container mt-4 mb-5" style="max-width: 640px;">

    <div class="text-center mb-4">
        <h2 style="font-family:'Cinzel',serif; color:#e9d5ff; letter-spacing:2px;">@Model.Title</h2>
        <p style="color:#a78bfa; font-size:0.9rem; letter-spacing:2px;">— ANIME DETAILS —</p>
    </div>

    <div class="anime-card">

        <div class="d-flex justify-content-between align-items-center py-3" style="border-bottom: 1px solid rgba(124,58,237,0.2);">
            <span style="color:#a78bfa; font-weight:700; letter-spacing:1px;">🎭 Genre</span>
            <span style="color:#e9d5ff;">@(Model.Genre ?? "—")</span>
        </div>

        <div class="d-flex justify-content-between align-items-center py-3" style="border-bottom: 1px solid rgba(124,58,237,0.2);">
            <span style="color:#a78bfa; font-weight:700; letter-spacing:1px;">📺 Episodes</span>
            <span style="color:#e9d5ff;">@(Model.Episodes?.ToString() ?? "—")</span>
        </div>

        <div class="d-flex justify-content-between align-items-center py-3" style="border-bottom: 1px solid rgba(124,58,237,0.2);">
            <span style="color:#a78bfa; font-weight:700; letter-spacing:1px;">📌 Status</span>
            <span>
                @{
                    var badgeClass = Model.Status switch
                    {
                        "Watching" => "bg-primary",
                        "Completed" => "bg-success",
                        "Dropped" => "bg-danger",
                        "On Hold" => "bg-warning text-dark",
                        _ => "bg-secondary"
                    };
                }
                <span class="badge @badgeClass">@Model.Status</span>
            </span>
        </div>

        <div class="d-flex justify-content-between align-items-center py-3" style="border-bottom: 1px solid rgba(124,58,237,0.2);">
            <span style="color:#a78bfa; font-weight:700; letter-spacing:1px;">⭐ Rating</span>
            <span style="color:#fbbf24; font-weight:700;">
                @if (Model.Rating.HasValue)
                {
                    @($"⭐ {Model.Rating} / 10")
                }
                else
                {
                    <span style="color:#6b7280;">—</span>
                }
            </span>
        </div>

        <div class="d-flex justify-content-between align-items-center py-3" style="border-bottom: 1px solid rgba(124,58,237,0.2);">
            <span style="color:#a78bfa; font-weight:700; letter-spacing:1px;">📝 Notes</span>
            <span style="color:#e9d5ff; text-align:right; max-width:60%;">@(Model.Notes ?? "—")</span>
        </div>

        <div class="d-flex justify-content-between align-items-center py-3">
            <span style="color:#a78bfa; font-weight:700; letter-spacing:1px;">🗓️ Date Added</span>
            <span style="color:#6b7280; font-size:0.9rem;">@Model.DateAdded.ToString("MMMM dd, yyyy")</span>
        </div>

    </div>

    <div class="d-flex gap-3 mt-4">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning flex-grow-1">✏️ Edit Anime</a>
        <a asp-action="Index" class="btn btn-secondary">← Back</a>
    </div>
</div>