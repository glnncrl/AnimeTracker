@model IEnumerable<AnimeTracker.Models.Anime>

@{
    ViewData["Title"] = "My Anime List";
}

<!-- Hero Banner -->
<div style="position:relative; width:100%; height:400px; overflow:hidden; margin-bottom:2rem;">
    <img src="~/images/anime-bg.jpg" alt="Anime Banner"
         style="width:100%; height:100%; object-fit:cover; object-position:center; filter:brightness(0.55);" />
    <div style="position:absolute; inset:0; background:linear-gradient(to bottom, rgba(13,13,26,0.2) 0%, rgba(13,13,26,0.95) 100%);"></div>
    <div style="position:absolute; inset:0; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:10px;">
        <div class="anime-hero-title">🎌 My Anime Collection</div>
        <div class="anime-hero-sub">✦ Track · Discover · Obsess ✦</div>
    </div>
</div>

<div class="container mb-5">

    <!-- Stats Row -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-2">
            <div class="stat-card">
                <div class="stat-number">@ViewData["TotalCount"]</div>
                <div class="stat-label">Total</div>
            </div>
        </div>
        <div class="col-6 col-md-2">
            <div class="stat-card" style="border-color: rgba(59,130,246,0.4);">
                <div class="stat-number" style="color:#60a5fa;">@ViewData["WatchingCount"]</div>
                <div class="stat-label">Watching</div>
            </div>
        </div>
        <div class="col-6 col-md-2">
            <div class="stat-card" style="border-color: rgba(34,197,94,0.4);">
                <div class="stat-number" style="color:#4ade80;">@ViewData["CompletedCount"]</div>
                <div class="stat-label">Completed</div>
            </div>
        </div>
        <div class="col-6 col-md-2">
            <div class="stat-card" style="border-color: rgba(124,58,237,0.4);">
                <div class="stat-number" style="color:#c084fc;">@ViewData["PlanCount"]</div>
                <div class="stat-label">Plan to Watch</div>
            </div>
        </div>
        <div class="col-6 col-md-2">
            <div class="stat-card" style="border-color: rgba(220,38,38,0.4);">
                <div class="stat-number" style="color:#f87171;">@ViewData["DroppedCount"]</div>
                <div class="stat-label">Dropped</div>
            </div>
        </div>
        <div class="col-6 col-md-2">
            <div class="stat-card" style="border-color: rgba(245,158,11,0.4);">
                <div class="stat-number" style="color:#fbbf24;">@ViewData["AvgRating"]</div>
                <div class="stat-label">Avg Rating</div>
            </div>
        </div>
    </div>

    <!-- Search / Filter / Sort Bar -->
    <div class="anime-card mb-4 py-3 px-4">
        <form method="get" asp-action="Index">
            <div class="row g-2 align-items-end">
                <div class="col-md-4">
                    <label class="form-label mb-1" style="font-size:0.8rem;">🔍 Search</label>
                    <input type="text" name="searchString" value="@ViewData["CurrentSearch"]"
                           class="form-control form-control-sm" placeholder="Title or genre..." />
                </div>
                <div class="col-md-3">
                    <label class="form-label mb-1" style="font-size:0.8rem;">📌 Status</label>
                    <select name="statusFilter" class="form-select form-select-sm">
                        <option value="">All Statuses</option>
                        @foreach (var s in new[] { "Watching", "Completed", "Plan to Watch", "On Hold", "Dropped" })
                        {
                            <option value="@s" selected="@(ViewData["CurrentStatus"]?.ToString() == s ? "selected" : null)">@s</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label mb-1" style="font-size:0.8rem;">↕️ Sort By</label>
                    <select name="sortOrder" class="form-select form-select-sm">
                        <option value="" selected="@(ViewData["CurrentSort"]?.ToString() == "" ? "selected" : null)">Newest First</option>
                        <option value="title_asc" selected="@(ViewData["CurrentSort"]?.ToString() == "title_asc" ? "selected" : null)">Title A→Z</option>
                        <option value="title_desc" selected="@(ViewData["CurrentSort"]?.ToString() == "title_desc" ? "selected" : null)">Title Z→A</option>
                        <option value="rating_desc" selected="@(ViewData["CurrentSort"]?.ToString() == "rating_desc" ? "selected" : null)">Rating High→Low</option>
                        <option value="rating_asc" selected="@(ViewData["CurrentSort"]?.ToString() == "rating_asc" ? "selected" : null)">Rating Low→High</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex gap-2">
                    <button type="submit" class="btn btn-primary btn-sm w-100">Apply</button>
                    <a asp-action="Index" class="btn btn-secondary btn-sm w-100">Reset</a>
                </div>
            </div>
        </form>
    </div>

    <!-- Add Button -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <span style="color:#a78bfa; font-size:0.9rem; letter-spacing:1px;">
            @Model.Count() result(s) found
        </span>
        <a asp-action="Create" class="btn btn-primary">+ Add Anime</a>
    </div>

    <!-- Table -->
    @if (!Model.Any())
    {
        <div class="alert alert-info text-center py-4">
            <div style="font-size:3rem;">🎭</div>
            <div class="mt-2">No anime found. Try a different search or <strong>add a new one!</strong></div>
        </div>
    }
    else
    {
        <div class="anime-card p-0 overflow-hidden">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Genre</th>
                        <th>Episodes</th>
                        <th>Status</th>
                        <th>Rating</th>
                        <th>Date Added</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold" style="color:#ffffff !important;">@item.Title</td>
                            <td style="color:#ffffff !important;">@item.Genre</td>
                            <td>@item.Episodes</td>
                            <td>
                                @{
                                    var badgeClass = item.Status switch
                                    {
                                        "Watching" => "bg-primary",
                                        "Completed" => "bg-success",
                                        "Dropped" => "bg-danger",
                                        "On Hold" => "bg-warning text-dark",
                                        _ => "bg-secondary"
                                    };
                                }
                                <span class="badge @badgeClass">@item.Status</span>
                            </td>
                            <td>
                                @if (item.Rating.HasValue)
                                {
                                    <span style="color:#fbbf24;">⭐ @item.Rating/10</span>
                                }
                            </td>
                            <td style="font-size:0.85rem;">@item.DateAdded.ToString("MMM dd, yyyy")</td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">Details</a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>