@model AnimeTracker.Models.Anime

@{
    ViewData["Title"] = "Add Anime";
}

<div class="container mt-4 mb-5" style="max-width: 620px;">

    <div class="text-center mb-4">
        <h2 style="font-family:'Cinzel',serif; color:#e9d5ff; letter-spacing:2px;">✨ Add New Anime</h2>
        <p style="color:#a78bfa; font-size:0.9rem; letter-spacing:1px;">Expand your sacred collection</p>
    </div>

    <div class="anime-card">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="mb-4">
                <label asp-for="Title" class="form-label">⚔️ Title</label>
                <input asp-for="Title" class="form-control" placeholder="e.g. Attack on Titan" />
                <span asp-validation-for="Title" class="text-danger" style="font-size:0.8rem;"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Genre" class="form-label">🎭 Genre</label>
                <input asp-for="Genre" class="form-control" placeholder="e.g. Action, Fantasy, Romance" />
            </div>

            <div class="mb-4">
                <label asp-for="Episodes" class="form-label">📺 Episodes</label>
                <input asp-for="Episodes" class="form-control" placeholder="e.g. 24" />
                <span asp-validation-for="Episodes" class="text-danger" style="font-size:0.8rem;"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Status" class="form-label">📌 Watch Status</label>
                <select asp-for="Status" class="form-select">
                    <option value="Plan to Watch">📋 Plan to Watch</option>
                    <option value="Watching">▶️ Watching</option>
                    <option value="Completed">✅ Completed</option>
                    <option value="On Hold">⏸️ On Hold</option>
                    <option value="Dropped">❌ Dropped</option>
                </select>
            </div>

            <div class="mb-4">
                <label asp-for="Rating" class="form-label">⭐ Your Rating (1–10)</label>
                <input asp-for="Rating" class="form-control" placeholder="e.g. 9" />
                <span asp-validation-for="Rating" class="text-danger" style="font-size:0.8rem;"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Notes" class="form-label">📝 Notes</label>
                <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Your thoughts, favorite moments..."></textarea>
            </div>

            <div class="d-flex gap-3 mt-4">
                <button type="submit" class="btn btn-primary flex-grow-1">🎌 Save to Collection</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}